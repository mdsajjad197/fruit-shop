{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://fruit-shop-orpin.vercel.app/api/:path*"
        },
        {
            "source": "/socket.io/:path*",
            "destination": "https://fruit-shop-orpin.vercel.app/socket.io/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/"
        }
    ]
}